VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# GEMINI_API_KEY is server-side only — set in Supabase Edge Functions secrets, never use VITE_ prefix
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret  # from FIRMA dashboard → Webhooks → signing secret
LEMON_SQUEEZY_API_KEY=your-lemon-squeezy-api-key
LEMON_SQUEEZY_WEBHOOK_SECRET=your-lemon-squeezy-webhook-secret  # from LS dashboard → Webhooks → signing secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key  # server-side only — never use VITE_ prefix
RESEND_API_KEY=your-resend-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key  # server-side only — Distance Matrix API, never use VITE_ prefix
VITE_PLAUSIBLE_DOMAIN=your-domain.com  # your-domain.com (e.g. app.prezta.fr)
VITE_SENTRY_DSN=  # from sentry.io project settings → Client Keys (DSN)
